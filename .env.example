# Copy to .env and fill in. Values are injected at container *creation* — after
# changing them, recreate the service (`docker compose up -d kairos`); a plain
# restart won't pick them up. See the Kairos repo for its full variable list.
TZ=Asia/Kolkata

# --- Kairos secrets (examples — replace with what your build needs) ---
NOTION_TOKEN=
OPENAI_API_KEY=
